---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const res = await fetch(`https://my-blog-api.tanjimvai.workers.dev/api/posts`);
const { posts } = await res.json();
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <h1>Amar Blog</h1>
      {posts.map((post: any) => (
        <article style="border: 1px solid #ccc; padding: 1rem; margin: 1rem 0; border-radius: 8px;">
          <h2>{post.title}</h2>
          <p>{post.content}</p>
          <small>{new Date(post.published_at).toLocaleDateString('bn-BD')}</small>
        </article>
      ))}
    </main>
    <Footer />
  </body>
</html>